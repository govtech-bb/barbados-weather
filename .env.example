# Copy to .env (gitignored) and fill in. All optional.
#
# IMPORTANT: .env is gitignored AND dockerignored — but treat it as a real
# secret store on your workstation: don't share, don't paste into chats, don't
# screen-share with values visible. For production, put these in AWS Secrets
# Manager / SSM Parameter Store (or your secret store of choice) and inject
# at runtime, not via .env baked into anything.
#
# Web Push: lets people opt in to storm alerts from the browser. Generate a
# keypair once with:  npx web-push generate-vapid-keys
# Without these, the "Get storm alerts" button is hidden and push is disabled.
# Rotating the keypair invalidates every existing subscription (the browser
# must re-subscribe) — see README "Rotating the VAPID keypair" for the
# procedure when you need to do that.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional: comma-separated host allowlist for push subscriptions. Defaults
# cover FCM / Mozilla autopush / Apple Web Push / WNS. Override only if you
# know what you're doing — narrowing this can break browsers; widening it
# undoes the SSRF defense in src/endpoint.mjs.
# PUSH_ALLOWED_HOSTS=

# AWS-backed alert channels (see compose.yaml for the rest)
# ALERT_EMAILS=
# SENDER_EMAIL=
# ALERT_PHONES=
# WEBHOOK_URL=
