{
  "name": "hurricane-ready-gov",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Bajan hurricane preparedness alerts: deterministic threat engine, AI briefings, multi-channel dispatch",
  "scripts": {
